{
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "mcp__kindex__*",
      "mcp__serena__*",
      "mcp__constrain__*",
      "mcp__claude_ai_Slack__*",
      "mcp__claude_ai_Linear__*",
      "mcp__claude_ai_Figma__*",
      "mcp__claude_ai_Amplitude__*",
      "mcp__grafana__*",
      "mcp__sentry__*",
      "WebSearch",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "Bash(git:*)",
      "Bash(pnpm:*)",
      "Bash(yarn:*)",
      "Bash(node:*)",
      "Bash(npx:*)",
      "Bash(gh:*)",
      "Bash(doppler:*)",
      "Bash(claude mcp:*)",
      "Bash(echo:*)",
      "Bash(test:*)",
      "Bash(find:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(which:*)",
      "Bash(pwd:*)",
      "Bash(grep:*)",
      "Bash(xargs:*)",
      "Bash(date:*)",
      "Bash(wcli:*)",
      "Bash(du:*)",
      "Bash(df:*)",
      "Bash(mv:*)",
      "Bash(mkdir:*)",
      "Bash(pgrep:*)",
      "Bash(pkill:*)",
      "Bash(osascript:*)",
      "Bash(brew:*)",
      "Bash(xcrun:*)",
      "Bash(mdls:*)",
      "Bash(defaults read:*)",
      "Bash(mount:*)",
      "Bash(tmutil:*)",
      "Bash(python3:*)",
      "Bash(rg:*)",
      "Bash(jq:*)",
      "Bash(git worktree:*)",
      "Bash(bc:*)",
      "Bash(paste:*)"
    ],
    "deny": [
      "Bash(git commit*Co-Authored-By*)",
      "Bash(git commit*co-authored-by*)",
      "Bash(git push --force *)",
      "Bash(git push --force)",
      "Bash(git push * --force *)",
      "Bash(git push * --force)"
    ]
  },
  "model": "claude-opus-4-8[1m]",
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.cargo/bin/signet-eval eval",
            "timeout": 10,
            "statusMessage": "Policy check..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/pre-commit-format.sh",
            "timeout": 30,
            "statusMessage": "Formatting staged files..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/post-edit-biome.sh",
            "timeout": 15,
            "statusMessage": "Running Biome lint...",
            "async": true
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/pre-compact.sh",
            "statusMessage": "Preserving session context..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/on-stop.sh",
            "timeout": 10,
            "statusMessage": "Checking for uncommitted changes..."
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/session-start.sh",
            "timeout": 5,
            "statusMessage": "Loading session guidance..."
          }
        ]
      }
    ]
  },
  "worktree": {
    "symlinkDirectories": [
      "node_modules",
      ".next",
      ".expo",
      ".turbo",
      "dist",
      ".yarn/cache"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "input=$(cat); user=$(whoami); host=$(hostname -s); dir=$(echo \"$input\" | jq -r '.workspace.current_dir // .cwd'); dir=\"${dir/#$HOME/~}\"; branch=$(git -C \"$(echo \"$input\" | jq -r '.workspace.current_dir // .cwd')\" --no-optional-locks symbolic-ref --short HEAD 2>/dev/null); model=$(echo \"$input\" | jq -r '.model.display_name // .model.id // \"\"'); used=$(echo \"$input\" | jq -r '.context_window.used_percentage // empty'); out=$(printf '\\033[36m%s@%s\\033[0m' \"$user\" \"$host\"); out=\"$out $(printf '\\033[2m|\\033[0m') $(printf '\\033[33m%s\\033[0m' \"$dir\")\"; [ -n \"$branch\" ] && out=\"$out $(printf '\\033[2m|\\033[0m') $(printf '\\033[32m%s\\033[0m' \"$branch\")\"; [ -n \"$model\" ] && out=\"$out $(printf '\\033[2m|\\033[0m') $(printf '\\033[2m%s\\033[0m' \"$model\")\"; [ -n \"$used\" ] && out=\"$out $(printf '\\033[2m|\\033[0m') $(printf '\\033[2mctx:%s%%\\033[0m' \"$(printf '%.0f' \"$used\")\")\"; printf '%s\\n' \"$out\""
  },
  "enabledPlugins": {
    "code-review@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": false,
    "pr-review-toolkit@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "hookify@claude-plugins-official": true,
    "caveman@caveman": true
  },
  "extraKnownMarketplaces": {
    "caveman": {
      "source": {
        "source": "github",
        "repo": "JuliusBrussee/caveman"
      }
    }
  },
  "effortLevel": "high",
  "enableWorkflows": true,
  "ultracode": false,
  "skipWorkflowUsageWarning": true,
  "showClearContextOnPlanAccept": true,
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark",
  "agentPushNotifEnabled": true,
  "autoMode": {
    "allow": [
      "Reading any file in the project",
      "Searching and grepping code",
      "Running type-check, lint, and test commands",
      "Running build commands",
      "Running codegen commands",
      "Installing dependencies with pnpm/yarn",
      "All kindex operations",
      "All serena operations",
      "All read-only git operations",
      "Creating and switching git branches",
      "Staging files and creating commits",
      "Reading Slack, GitHub, Linear, and Figma"
    ],
    "soft_deny": [
      "Pushing code to any remote repository",
      "Creating, closing, or commenting on pull requests or issues",
      "Sending messages to Slack, email, or any external communication service",
      "Deleting files, branches, or any persistent resources",
      "Modifying CI/CD pipelines or deployment configs",
      "Running database migrations or destructive database operations",
      "Modifying environment variables or secrets in Doppler",
      "Force-pushing or rewriting git history",
      "Installing new dependencies or upgrading major versions",
      "Creating or modifying Linear issues"
    ],
    "environment": [
      "macOS development machine",
      "Multi-project workspace across Next.js, Node backend, and React Native/Expo repos",
      "Package managers vary per repo (pnpm/yarn/npm) — check the lockfile",
      "Biome for linting/formatting, Prisma for DB, Doppler for env vars",
      "Conductor for multi-agent orchestration"
    ]
  }
}
